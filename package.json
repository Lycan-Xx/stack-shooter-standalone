{
  "private": true,
  "name": "stack-shooter",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd src/client && vite build",
    "build:server": "cd src/server && vite build",
    "check": "npm run type-check && npm run lint:fix && npm run prettier",
    "dev": "concurrently -k -p \"[{name}]\" -n \"CLIENT,SERVER\" -c \"blue,green\" \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd src/client && vite --port 7474",
    "dev:server": "ts-node-dev --project src/server/tsconfig.json src/server/index.ts",
    "start": "node dist/server/index.js",
    "postinstall": "npm run build",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "prettier": "prettier-package-json --write ./package.json && prettier --write .",
    "type-check": "tsc --build"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "clsx": "2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "5.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "3.3.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "9.23.0",
    "@tailwindcss/vite": "4.1.6",
    "@types/cors": "^2.8.19",
    "@types/express": "5.0.1",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "@vitejs/plugin-react": "4.4.1",
    "concurrently": "9.1.2",
    "dotenv-cli": "8.0.0",
    "eslint": "9.23.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "15.15.0",
    "prettier": "3.5.3",
    "prettier-package-json": "2.8.0",
    "prettier-plugin-tailwindcss": "0.6.11",
    "tailwindcss": "4.1.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.29.0",
    "vite": "6.2.4",
    "vitest": "3.1.1"
  }
}
